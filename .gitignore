# =============================================================
# .gitignore — Generated by generate_gitignore.py
# Date      : 2026-03-29
# Templates : os/windows, languages/python, editors/vscode, temp/temporary-files
# =============================================================

# =================================
# Template: Windows
# Category: Operating System
# =================================
# Covers files automatically generated by the Windows OS,
# Windows Explorer, and system utilities. These files are
# machine-specific and have no value in version control.


# ---------------------------------
# Thumbnail Cache
# ---------------------------------
# Windows Explorer generates these to store image previews.
# They are rebuilt automatically and vary per machine.
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# ---------------------------------
# Desktop Configuration
# ---------------------------------
# Stores folder display preferences (icon positions, view mode).
# Entirely local to the current user's machine.
Desktop.ini
desktop.ini

# ---------------------------------
# Recycle Bin
# ---------------------------------
# Files staged for deletion by Windows. Never relevant to source code.
$RECYCLE.BIN/

# ---------------------------------
# Windows Shortcuts & Shell Links
# ---------------------------------
# .lnk files are Windows shortcut files. Committing them is
# almost always accidental and they break on other machines.
*.lnk

# ---------------------------------
# Prefetch Files
# ---------------------------------
# Performance data generated by Windows for faster app launches.
# Machine-specific, changes constantly, not source-related.
*.pf

# ---------------------------------
# Volume Shadow Copy & System Files
# ---------------------------------
# Low-level Windows system files. Never belong in a repo.
*.stackdump
[Dd]esktop.ini

# ---------------------------------
# Windows Installer Artifacts
# ---------------------------------
# Temporary files generated during software installation.
*.msi
*.msix
*.msm
*.msp

# ---------------------------------
# Windows Image Backup
# ---------------------------------
# Backup files created by Windows Image Backup utility.
*.wim

# ---------------------------------
# Dump Files
# ---------------------------------
# Crash dump files generated when a Windows process fails.
# Useful for local debugging but should never be committed.
*.dmp

# =================================
# Template: Python
# Category: Programming Language
# =================================
# Covers files generated by the Python interpreter, package
# managers (pip, Poetry, PDM), testing frameworks, linters,
# type checkers, and build tools. Based on community conventions
# from python/cpython and popular open-source Python projects.


# ---------------------------------
# Bytecode & Compiled Extensions
# ---------------------------------
# Python compiles .py files to bytecode for faster execution.
# These are machine- and version-specific; always regenerated.
__pycache__/
*.py[cod]          # .pyc (compiled), .pyo (optimised), .pyd (Windows DLL)
*$py.class         # Jython compiled class files

# ---------------------------------
# C Extension Build Artifacts
# ---------------------------------
# Files produced when building CPython C extensions via setup.py
# or a PEP 517 build backend (e.g. setuptools, meson-python).
*.so               # Shared object (Linux/macOS compiled extension)
*.pyd              # Windows compiled extension (also matched above)

# ---------------------------------
# Distribution / Packaging
# ---------------------------------
# build/         — setuptools build directory
# dist/          — wheel and sdist output directory
# *.egg-info/    — package metadata generated by setuptools
# *.egg          — old-style egg distribution format
# MANIFEST       — auto-generated file manifest (sdist)
build/
dist/
*.egg-info/
*.egg
MANIFEST

# ---------------------------------
# Virtual Environments
# ---------------------------------
# Virtualenv, venv, and conda envs contain platform-specific
# interpreter binaries and installed packages. They must not
# be committed; developers recreate them from requirements files.
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/

# ---------------------------------
# Environment Variable Files
# ---------------------------------
# .env files typically store secrets (API keys, DB credentials).
# NEVER commit these. Use .env.example for safe templates.
.env
.env.*
!.env.example      # Allow the example/template file to be committed

# ---------------------------------
# pip & Package Manager Caches
# ---------------------------------
# pip download and wheel caches. Regenerated automatically.
pip-log.txt
pip-delete-this-directory.txt
.pip/

# ---------------------------------
# Poetry
# ---------------------------------
# Poetry's local virtual environment folder (when virtualenvs
# are configured to be stored inside the project).
.poetry/

# ---------------------------------
# PDM
# ---------------------------------
.pdm.toml
.pdm-python
__pypackages__/    # PEP 582 local package directory used by PDM

# ---------------------------------
# Testing & Coverage
# ---------------------------------
# pytest cache stores test results between runs for --lf/--ff flags.
# htmlcov/ and .coverage are output from coverage.py.
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
nosetests.xml

# ---------------------------------
# Type Checkers
# ---------------------------------
# mypy type-checking cache; dmypy is the daemon socket file.
.mypy_cache/
.dmypy.json
dmypy.json

# pyright stores project-specific type information here.
.pyright/
pyrightconfig.json  # Often machine-specific; consider case-by-case

# ---------------------------------
# Linters & Formatters
# ---------------------------------
# Ruff and flake8 cache their results for performance.
.ruff_cache/
.flake8

# ---------------------------------
# Jupyter Notebooks
# ---------------------------------
# Notebook checkpoint files are auto-saved copies. They contain
# redundant state and clutter diffs; typically not committed.
.ipynb_checkpoints/

# ---------------------------------
# Sphinx Documentation Build
# ---------------------------------
# The /docs/_build directory holds generated HTML/PDF output.
# Source .rst/.md files should be committed; build artifacts should not.
docs/_build/
docs/_autosummary/

# ---------------------------------
# PyInstaller
# ---------------------------------
# Spec and build files generated when bundling a Python app
# into a standalone executable via PyInstaller.
*.spec
# dist/ already covered above

# ---------------------------------
# Translations (Babel / gettext)
# ---------------------------------
# Compiled message object files. Derived from .po source files.
*.mo
*.pot

# =================================
# Template: Visual Studio Code
# Category: Editor / IDE
# =================================
# Covers files generated by VS Code that are local to a specific
# developer's machine or workspace. Some .vscode/ files CAN and
# SHOULD be committed (see notes below); this template only ignores
# the ones that are typically machine-specific or auto-generated.


# ---------------------------------
# VS Code Workspace Folder
# ---------------------------------
# The .vscode/ directory contains multiple file types with very
# different commit policies. Rules are applied selectively below.

# Per-developer private settings (keyboard shortcuts, UI state).
# These override workspace defaults and should NOT be shared.
.vscode/settings.json        # Contains local paths, personal preferences

# NOTE: The following .vscode/ files are COMMONLY COMMITTED and
# should NOT be ignored if your team wants to share them:
#   .vscode/extensions.json  — recommended extensions list
#   .vscode/tasks.json       — shared build/test task definitions
#   .vscode/launch.json      — shared debug configurations
#   .vscode/snippets/        — shared code snippets
#
# To commit them, remove them from this ignore file or negate:
# !.vscode/extensions.json
# !.vscode/tasks.json
# !.vscode/launch.json

# ---------------------------------
# Workspace Files
# ---------------------------------
# .code-workspace files define multi-root workspaces. They can be
# committed if the team shares the same workspace layout, but are
# often personal. Adjust based on your team's workflow.
*.code-workspace

# ---------------------------------
# Local History Extension
# ---------------------------------
# The "Local History" VS Code extension stores per-file edit history
# in this directory. It is personal to the developer's machine.
.history/

# ---------------------------------
# VS Code Extension Storage
# ---------------------------------
# Some extensions write data to these locations inside the project.
# They are always local and should not be shared.
.vscode-test/      # VS Code Extension testing framework output
*.vsix             # VS Code extension package — a build artifact

# ---------------------------------
# Live Share
# ---------------------------------
# VS Code Live Share creates a temporary workspace description file.
# This is session-specific and should never be committed.
.vsls.json

# =================================
# Template: Temporary & System Files
# Category: Temporary / General
# =================================
# Covers generic temporary, cache, log, and build artifact files
# that appear across many different tools and platforms. This
# template is designed to complement language- and OS-specific
# templates by catching common cross-cutting patterns.


# ---------------------------------
# Log Files
# ---------------------------------
# Log files are generated at runtime and typically contain
# ephemeral operational data, errors, or sensitive information.
# They should never be committed.
*.log
*.log.*            # Rotated logs (e.g. app.log.1, app.log.2026-03-01)
logs/
log/

# ---------------------------------
# Generic Temporary Files
# ---------------------------------
# Files commonly left by editors, compilers, and OS utilities
# as temporary working copies or crash recovery files.
*.tmp
*.temp
*.bak              # Generic backup file
*.backup
*.old              # Older version of a file left during editing
*.orig             # Original file preserved during a merge or patch
*.rej              # Rejected patch hunks (output of `patch`)
*~                 # Tilde-suffixed editor backups (Emacs, gedit, etc.)

# ---------------------------------
# Swap Files
# ---------------------------------
# Swap files are created by terminal text editors (Vim, Nano)
# as crash-recovery buffers. They contain unsaved edit state.
*.swp              # Vim main swap file
*.swo              # Vim secondary swap file (overflow)
*.swn              # Vim tertiary swap file
.*.swp             # Hidden Vim swap (e.g. .myfile.py.swp)
*.swm

# ---------------------------------
# Cache Directories & Files
# ---------------------------------
# Generic cache directories used by package managers,
# build tools, linters, and test runners.
.cache/
cache/
*.cache
__pycache__/       # Python (also in Python template; safe to duplicate)
.sass-cache/       # Sass CSS preprocessor cache

# ---------------------------------
# Compiled / Minified Assets
# ---------------------------------
# Minified JS/CSS and sourcemaps are always derived from source.
# They should be generated during the build/deploy step, not committed.
*.min.js
*.min.css
*.map              # Source maps (JS / CSS)

# ---------------------------------
# Build Artifacts & Directories
# ---------------------------------
# Generic build output directory names used across many ecosystems.
# Language-specific templates cover their own build dirs; this
# catches anything not covered elsewhere.
build/
dist/
out/
output/
target/
release/

# ---------------------------------
# Compressed / Archive Files
# ---------------------------------
# Archives are almost always build outputs or downloaded dependencies.
# Committing them bloats the repository history permanently.
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tar.xz
*.rar
*.7z
*.gz
*.bz2
*.xz

# ---------------------------------
# Database Files (local)
# ---------------------------------
# Local SQLite and similar embedded database files used during
# development. They contain runtime state and often credentials.
*.sqlite
*.sqlite3
*.db
*.db3

# ---------------------------------
# Generated Documentation
# ---------------------------------
# HTML/PDF documentation produced by doc generators (Sphinx,
# JSDoc, Doxygen, etc.). Always derived from source comments.
docs/_build/
docs/build/
site/              # MkDocs default output directory
_site/             # Jekyll output directory

# ---------------------------------
# Secret / Credential Files
# ---------------------------------
# Any file whose name suggests it contains secrets.
# These patterns catch common naming conventions.
*.pem              # Privacy-Enhanced Mail (TLS certificates, private keys)
*.key              # Private key file
*.p12              # PKCS#12 certificate bundle
*.pfx              # Windows certificate bundle (equivalent to .p12)
*.crt              # Certificate file (often safe to commit, but err on caution)
*.cer              # Certificate file (Windows)
credentials
credentials.json
secrets.json
secrets.yaml
secrets.yml
*.secret
.secrets/

# ---------------------------------
# Coverage Reports
# ---------------------------------
# Test coverage output from any language or framework.
coverage/
*.coverage
coverage.xml
coverage.json
lcov.info
*.lcov

# ---------------------------------
# Patch Files
# ---------------------------------
# Diff/patch files from version control operations.
# Usually ephemeral working files; not source artifacts.
*.diff
*.patch
